      "parameters": {
        "sendTo": "lovepehlaj2005@gmail.com",
        "subject": "Congratulations! Interview Scheduled",
        "message": "=<!DOCTYPE html>\n\n<html>\n\n<body style=\"margin:0;padding:30px;background:#f5f7fb;font-family:Arial,sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n<tr>\n<td align=\"center\">\n\n<table width=\"650\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:10px;overflow:hidden;\">\n\n<tr>\n<td style=\"background:#1565C0;padding:30px;text-align:center;color:white;\">\n\n<h1 style=\"margin:0;\">Congratulations!</h1>\n\n<p style=\"margin-top:10px;\">\nYou have been shortlisted for the next stage.\n</p>\n\n</td>\n</tr>\n\n<tr>\n<td style=\"padding:35px;\">\n\n<p>Hello <strong>{{ $('Save Candidate in CRM').item.json['Candidate Name'] }}</strong>,</p>\n\n<p>\nThank you for applying for the\n<strong>{{ $('Save Candidate in CRM').item.json.Position }}</strong>\nposition.\n</p>\n\n<p>\nOur recruitment team has reviewed your application, and we are pleased to invite you to the interview stage.\n</p>\n\n<table width=\"100%\" cellpadding=\"10\" style=\"border-collapse:collapse;margin-top:20px;border:1px solid #ddd;\">\n\n<tr>\n<td><strong>Interview Date and Time: </strong></td>\n<td>\n {{ DateTime.fromISO($('Create Interview Event').item.json.start.dateTime).toFormat(\"dd LLL yyyy, hh:mm a\") }}</td>\n</tr>\n\n<tr>\n<td><strong>Meeting Link: </strong></td>\n<td>\n<a href=\"https://abc.google.meet\">\nJoin Interview\n</a>\n</td>\n</tr>\n\n</table>\n\n<p style=\"margin-top:25px;\">\nPlease ensure you join the meeting 10 minutes before the scheduled time.\n</p>\n\n<p>\nIf you have any questions, simply reply to this email.\n</p>\n\n<p>\nBest Regards,<br>\n<strong>HR Recruitment Team</strong>\n</p>\n\n</td>\n</tr>\n\n<tr>\n\n<td style=\"background:#eeeeee;padding:20px;text-align:center;font-size:12px;color:#666;\">\n\nAI Recruitment Platform\n\n</td>\n\n</tr>\n\n</table>\n\n</td>\n\n</tr>\n\n</table>\n\n</body>\n\n</html>\n",
        "options": {
          "appendAttribution": false
        }
