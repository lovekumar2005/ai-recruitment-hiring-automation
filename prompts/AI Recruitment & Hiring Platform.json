    {
      "parameters": {
        "jsCode": "let aiResponse = $input.first().json.output;\n\n// Remove markdown\naiResponse = aiResponse\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\n// Parse JSON\nconst data = JSON.parse(aiResponse);\n\nreturn [\n  {\n    json: {\n      candidate_name: data.candidate_name,\n      email: data.email,\n      position_applied: data.position_applied,\n      overall_score: data.overall_score,\n      rating: data.rating,\n      category: data.category,\n      seniority_level: data.seniority_level,\n      experience_years: data.experience_years,\n\n      technical_skills: data.technical_skills.join(\", \"),\n      soft_skills: data.soft_skills.join(\", \"),\n\n      education: data.education,\n\n      strengths: data.strengths.join(\", \"),\n      weaknesses: data.weaknesses.join(\", \"),\n      missing_information: data.missing_information.join(\", \"),\n\n      summary: data.summary,\n\n      recommended_for_interview: data.recommended_for_interview,\n\n      interview_questions: data.interview_questions.join(\"\\n\\n\")\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        -224
      ],
      "id": "8ec53763-4cac-4e5a-bc46-a071f19fe0b2",
      "name": "Parse AI Response"
    },
